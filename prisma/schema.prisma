generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex", "fullTextSearch"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model article_revisions {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  article_id       BigInt   @db.UnsignedBigInt
  revision_number  Int      @db.UnsignedInt
  title            String   @db.VarChar(255)
  excerpt          String?  @db.Text
  content_markdown String?  @db.LongText
  content_html     String?  @db.LongText
  content_json     String?  @db.LongText
  changed_by       BigInt?  @db.UnsignedBigInt
  change_summary   String?  @db.VarChar(500)
  created_at       DateTime @default(now()) @db.DateTime(0)
  articles         articles @relation(fields: [article_id], references: [id], onDelete: Cascade, map: "fk_article_revisions_article")
  users            users?   @relation(fields: [changed_by], references: [id], map: "fk_article_revisions_user")

  @@unique([article_id, revision_number], map: "uq_article_revision")
  @@index([changed_by], map: "fk_article_revisions_user")
}

model article_tags {
  article_id BigInt   @db.UnsignedBigInt
  tag_id     BigInt   @db.UnsignedBigInt
  created_at DateTime @default(now()) @db.DateTime(0)
  articles   articles @relation(fields: [article_id], references: [id], onDelete: Cascade, map: "fk_article_tags_article")
  tags       tags     @relation(fields: [tag_id], references: [id], onDelete: Cascade, map: "fk_article_tags_tag")

  @@id([article_id, tag_id])
  @@index([tag_id], map: "fk_article_tags_tag")
}

model articles {
  id                               BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  author_id                        BigInt?               @db.UnsignedBigInt
  destination_id                   BigInt?               @db.UnsignedBigInt
  content_type                     articles_content_type @default(guide)
  title                            String                @db.VarChar(255)
  slug                             String                @db.VarChar(220)
  excerpt                          String?               @db.Text
  content_markdown                 String?               @db.LongText
  content_html                     String?               @db.LongText
  content_json                     String?               @db.LongText
  hero_media_id                    BigInt?               @db.UnsignedBigInt
  table_of_contents_json           String?               @db.LongText
  reading_time_minutes             Int?                  @db.UnsignedSmallInt
  word_count                       Int?                  @db.UnsignedInt
  status                           articles_status       @default(draft)
  visibility                       articles_visibility   @default(public)
  password_hash                    String?               @db.VarChar(255)
  is_featured                      Boolean               @default(false)
  allow_comments                   Boolean               @default(false)
  scheduled_at                     DateTime?             @db.DateTime(0)
  published_at                     DateTime?             @db.DateTime(0)
  created_by                       BigInt?               @db.UnsignedBigInt
  updated_by                       BigInt?               @db.UnsignedBigInt
  created_at                       DateTime              @default(now()) @db.DateTime(0)
  updated_at                       DateTime              @default(now()) @db.DateTime(0)
  deleted_at                       DateTime?             @db.DateTime(0)
  article_revisions                article_revisions[]
  article_tags                     article_tags[]
  authors                          authors?              @relation(fields: [author_id], references: [id], map: "fk_articles_author")
  users_articles_created_byTousers users?                @relation("articles_created_byTousers", fields: [created_by], references: [id], map: "fk_articles_created_by")
  destinations                     destinations?         @relation(fields: [destination_id], references: [id], map: "fk_articles_destination")
  media                            media?                @relation(fields: [hero_media_id], references: [id], map: "fk_articles_hero_media")
  users_articles_updated_byTousers users?                @relation("articles_updated_byTousers", fields: [updated_by], references: [id], map: "fk_articles_updated_by")
  content_imports                  content_imports[]

  @@unique([content_type, slug], map: "uq_articles_type_slug")
  @@index([created_by], map: "fk_articles_created_by")
  @@index([hero_media_id], map: "fk_articles_hero_media")
  @@index([updated_by], map: "fk_articles_updated_by")
  @@index([author_id], map: "idx_articles_author")
  @@index([destination_id], map: "idx_articles_destination")
  @@index([is_featured], map: "idx_articles_featured")
  @@index([content_type, status, published_at], map: "idx_articles_type_status_date")
  @@fulltext([title, excerpt, content_html], map: "ft_articles_content")
}

model attractions {
  id                                  BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  destination_id                      BigInt?            @db.UnsignedBigInt
  name                                String             @db.VarChar(255)
  slug                                String             @unique(map: "uq_attractions_slug") @db.VarChar(220)
  short_description                   String?            @db.VarChar(1000)
  content_html                        String?            @db.LongText
  content_json                        String?            @db.LongText
  history                             String?            @db.LongText
  things_to_do                        String?            @db.LongText
  best_time_to_visit                  String?            @db.VarChar(500)
  recommended_duration                String?            @db.VarChar(100)
  entry_fee                           String?            @db.VarChar(255)
  timings                             String?            @db.VarChar(255)
  address                             String?            @db.VarChar(1000)
  latitude                            Decimal?           @db.Decimal(10, 7)
  longitude                           Decimal?           @db.Decimal(10, 7)
  google_maps_url                     String?            @db.VarChar(1000)
  phone                               String?            @db.VarChar(30)
  email                               String?            @db.VarChar(255)
  website_url                         String?            @db.VarChar(500)
  hero_media_id                       BigInt?            @db.UnsignedBigInt
  is_featured                         Boolean            @default(false)
  is_verified                         Boolean            @default(false)
  family_friendly                     Boolean            @default(false)
  parking_available                   Boolean            @default(false)
  status                              attractions_status @default(draft)
  published_at                        DateTime?          @db.DateTime(0)
  created_by                          BigInt?            @db.UnsignedBigInt
  updated_by                          BigInt?            @db.UnsignedBigInt
  created_at                          DateTime           @default(now()) @db.DateTime(0)
  updated_at                          DateTime           @default(now()) @db.DateTime(0)
  deleted_at                          DateTime?          @db.DateTime(0)
  users_attractions_created_byTousers users?             @relation("attractions_created_byTousers", fields: [created_by], references: [id], map: "fk_attractions_created_by")
  destinations                        destinations?      @relation(fields: [destination_id], references: [id], map: "fk_attractions_destination")
  media                               media?             @relation(fields: [hero_media_id], references: [id], map: "fk_attractions_hero_media")
  users_attractions_updated_byTousers users?             @relation("attractions_updated_byTousers", fields: [updated_by], references: [id], map: "fk_attractions_updated_by")

  @@index([created_by], map: "fk_attractions_created_by")
  @@index([hero_media_id], map: "fk_attractions_hero_media")
  @@index([updated_by], map: "fk_attractions_updated_by")
  @@index([destination_id, status], map: "idx_attractions_destination_status")
  @@index([is_featured], map: "idx_attractions_featured")
  @@fulltext([name, short_description, content_html], map: "ft_attractions_content")
}

model audit_logs {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id         BigInt?  @db.UnsignedBigInt
  action          String   @db.VarChar(150)
  entity_type     String?  @db.VarChar(50)
  entity_id       BigInt?  @db.UnsignedBigInt
  old_values_json String?  @db.LongText
  new_values_json String?  @db.LongText
  ip_address      String?  @db.VarChar(45)
  user_agent      String?  @db.VarChar(1000)
  created_at      DateTime @default(now()) @db.DateTime(0)
  users           users?   @relation(fields: [user_id], references: [id], map: "fk_audit_logs_user")

  @@index([action], map: "idx_audit_action")
  @@index([entity_type, entity_id, created_at], map: "idx_audit_entity")
  @@index([user_id, created_at], map: "idx_audit_user_date")
}

model authors {
  id               BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  user_id          BigInt?        @unique(map: "uq_authors_user") @db.UnsignedBigInt
  name             String         @db.VarChar(150)
  slug             String         @unique(map: "uq_authors_slug") @db.VarChar(180)
  designation      String?        @db.VarChar(150)
  short_bio        String?        @db.VarChar(500)
  full_bio         String?        @db.Text
  profile_media_id BigInt?        @db.UnsignedBigInt
  email            String?        @db.VarChar(255)
  website_url      String?        @db.VarChar(500)
  facebook_url     String?        @db.VarChar(500)
  instagram_url    String?        @db.VarChar(500)
  linkedin_url     String?        @db.VarChar(500)
  twitter_url      String?        @db.VarChar(500)
  status           authors_status @default(active)
  created_at       DateTime       @default(now()) @db.DateTime(0)
  updated_at       DateTime       @default(now()) @db.DateTime(0)
  deleted_at       DateTime?      @db.DateTime(0)
  articles         articles[]
  media            media?         @relation(fields: [profile_media_id], references: [id], map: "fk_authors_profile_media")
  users            users?         @relation(fields: [user_id], references: [id], map: "fk_authors_user")

  @@index([profile_media_id], map: "fk_authors_profile_media")
}

model business_hours {
  id                BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  business_id       BigInt     @db.UnsignedBigInt
  day_of_week       Int        @db.UnsignedTinyInt
  is_closed         Boolean    @default(false)
  open_time         DateTime?  @db.Time(0)
  close_time        DateTime?  @db.Time(0)
  second_open_time  DateTime?  @db.Time(0)
  second_close_time DateTime?  @db.Time(0)
  created_at        DateTime   @default(now()) @db.DateTime(0)
  updated_at        DateTime   @default(now()) @db.DateTime(0)
  businesses        businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, map: "fk_business_hours_business")

  @@unique([business_id, day_of_week], map: "uq_business_hours_day")
}

model business_services {
  id            BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  business_id   BigInt                   @db.UnsignedBigInt
  name          String                   @db.VarChar(255)
  slug          String                   @db.VarChar(220)
  description   String?                  @db.Text
  price_from    Decimal?                 @db.Decimal(12, 2)
  price_to      Decimal?                 @db.Decimal(12, 2)
  currency      String                   @default("INR") @db.Char(3)
  display_order Int                      @default(0)
  status        business_services_status @default(active)
  created_at    DateTime                 @default(now()) @db.DateTime(0)
  updated_at    DateTime                 @default(now()) @db.DateTime(0)
  businesses    businesses               @relation(fields: [business_id], references: [id], onDelete: Cascade, map: "fk_business_services_business")

  @@unique([business_id, slug], map: "uq_business_service_slug")
}

model business_submissions {
  id                                                     BigInt                      @id @default(autoincrement()) @db.UnsignedBigInt
  submitted_by_user_id                                   BigInt?                     @db.UnsignedBigInt
  business_name                                          String                      @db.VarChar(255)
  category_id                                            BigInt?                     @db.UnsignedBigInt
  destination_id                                         BigInt?                     @db.UnsignedBigInt
  contact_name                                           String                      @db.VarChar(150)
  phone                                                  String?                     @db.VarChar(30)
  whatsapp_number                                        String?                     @db.VarChar(30)
  email                                                  String?                     @db.VarChar(255)
  website_url                                            String?                     @db.VarChar(500)
  address                                                String?                     @db.VarChar(1000)
  description                                            String?                     @db.Text
  submission_payload_json                                String?                     @db.LongText
  status                                                 business_submissions_status @default(pending)
  reviewed_by                                            BigInt?                     @db.UnsignedBigInt
  reviewed_at                                            DateTime?                   @db.DateTime(0)
  rejection_reason                                       String?                     @db.Text
  created_at                                             DateTime                    @default(now()) @db.DateTime(0)
  updated_at                                             DateTime                    @default(now()) @db.DateTime(0)
  categories                                             categories?                 @relation(fields: [category_id], references: [id], map: "fk_business_submissions_category")
  destinations                                           destinations?               @relation(fields: [destination_id], references: [id], map: "fk_business_submissions_destination")
  users_business_submissions_reviewed_byTousers          users?                      @relation("business_submissions_reviewed_byTousers", fields: [reviewed_by], references: [id], map: "fk_business_submissions_reviewer")
  users_business_submissions_submitted_by_user_idTousers users?                      @relation("business_submissions_submitted_by_user_idTousers", fields: [submitted_by_user_id], references: [id], map: "fk_business_submissions_user")

  @@index([category_id], map: "fk_business_submissions_category")
  @@index([destination_id], map: "fk_business_submissions_destination")
  @@index([reviewed_by], map: "fk_business_submissions_reviewer")
  @@index([submitted_by_user_id], map: "fk_business_submissions_user")
  @@index([status, created_at], map: "idx_business_submissions_status")
}

model businesses {
  id                                     BigInt                         @id @default(autoincrement()) @db.UnsignedBigInt
  owner_user_id                          BigInt?                        @db.UnsignedBigInt
  destination_id                         BigInt?                        @db.UnsignedBigInt
  name                                   String                         @db.VarChar(255)
  slug                                   String                         @unique(map: "uq_businesses_slug") @db.VarChar(220)
  legal_name                             String?                        @db.VarChar(255)
  short_description                      String?                        @db.VarChar(1000)
  content_html                           String?                        @db.LongText
  content_json                           String?                        @db.LongText
  logo_media_id                          BigInt?                        @db.UnsignedBigInt
  cover_media_id                         BigInt?                        @db.UnsignedBigInt
  phone                                  String?                        @db.VarChar(30)
  alternate_phone                        String?                        @db.VarChar(30)
  whatsapp_number                        String?                        @db.VarChar(30)
  email                                  String?                        @db.VarChar(255)
  website_url                            String?                        @db.VarChar(500)
  facebook_url                           String?                        @db.VarChar(500)
  instagram_url                          String?                        @db.VarChar(500)
  youtube_url                            String?                        @db.VarChar(500)
  linkedin_url                           String?                        @db.VarChar(500)
  address_line_1                         String?                        @db.VarChar(500)
  address_line_2                         String?                        @db.VarChar(500)
  postal_code                            String?                        @db.VarChar(20)
  latitude                               Decimal?                       @db.Decimal(10, 7)
  longitude                              Decimal?                       @db.Decimal(10, 7)
  google_maps_url                        String?                        @db.VarChar(1000)
  price_range                            String?                        @db.VarChar(100)
  is_featured                            Boolean                        @default(false)
  is_verified                            Boolean                        @default(false)
  verification_status                    businesses_verification_status @default(unverified)
  claim_status                           businesses_claim_status        @default(unclaimed)
  status                                 businesses_status              @default(draft)
  published_at                           DateTime?                      @db.DateTime(0)
  created_by                             BigInt?                        @db.UnsignedBigInt
  updated_by                             BigInt?                        @db.UnsignedBigInt
  created_at                             DateTime                       @default(now()) @db.DateTime(0)
  updated_at                             DateTime                       @default(now()) @db.DateTime(0)
  deleted_at                             DateTime?                      @db.DateTime(0)
  business_hours                         business_hours[]
  business_services                      business_services[]
  media_businesses_cover_media_idTomedia media?                         @relation("businesses_cover_media_idTomedia", fields: [cover_media_id], references: [id], map: "fk_businesses_cover_media")
  users_businesses_created_byTousers     users?                         @relation("businesses_created_byTousers", fields: [created_by], references: [id], map: "fk_businesses_created_by")
  destinations                           destinations?                  @relation(fields: [destination_id], references: [id], map: "fk_businesses_destination")
  media_businesses_logo_media_idTomedia  media?                         @relation("businesses_logo_media_idTomedia", fields: [logo_media_id], references: [id], map: "fk_businesses_logo_media")
  users_businesses_owner_user_idTousers  users?                         @relation("businesses_owner_user_idTousers", fields: [owner_user_id], references: [id], map: "fk_businesses_owner")
  users_businesses_updated_byTousers     users?                         @relation("businesses_updated_byTousers", fields: [updated_by], references: [id], map: "fk_businesses_updated_by")
  events                                 events[]
  hotel_profiles                         hotel_profiles?

  @@index([cover_media_id], map: "fk_businesses_cover_media")
  @@index([created_by], map: "fk_businesses_created_by")
  @@index([logo_media_id], map: "fk_businesses_logo_media")
  @@index([updated_by], map: "fk_businesses_updated_by")
  @@index([destination_id, status], map: "idx_businesses_destination_status")
  @@index([owner_user_id], map: "idx_businesses_owner")
  @@index([is_verified, is_featured], map: "idx_businesses_verified_featured")
  @@fulltext([name, short_description, content_html], map: "ft_businesses_content")
}

model categories {
  id                   BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  parent_id            BigInt?                @db.UnsignedBigInt
  scope                categories_scope
  name                 String                 @db.VarChar(180)
  slug                 String                 @db.VarChar(180)
  description          String?                @db.Text
  icon                 String?                @db.VarChar(100)
  featured_media_id    BigInt?                @db.UnsignedBigInt
  display_order        Int                    @default(0)
  status               categories_status      @default(active)
  created_at           DateTime               @default(now()) @db.DateTime(0)
  updated_at           DateTime               @default(now()) @db.DateTime(0)
  business_submissions business_submissions[]
  media                media?                 @relation(fields: [featured_media_id], references: [id], map: "fk_categories_featured_media")
  categories           categories?            @relation("categoriesTocategories", fields: [parent_id], references: [id], map: "fk_categories_parent")
  other_categories     categories[]           @relation("categoriesTocategories")
  entity_categories    entity_categories[]

  @@unique([scope, slug], map: "uq_categories_scope_slug")
  @@index([featured_media_id], map: "fk_categories_featured_media")
  @@index([parent_id], map: "idx_categories_parent")
  @@index([scope, status], map: "idx_categories_scope_status")
}

model contact_submissions {
  id          BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  name        String                     @db.VarChar(150)
  email       String?                    @db.VarChar(255)
  phone       String?                    @db.VarChar(30)
  subject     String?                    @db.VarChar(255)
  message     String                     @db.Text
  source_path String?                    @db.VarChar(500)
  status      contact_submissions_status @default(new)
  assigned_to BigInt?                    @db.UnsignedBigInt
  created_at  DateTime                   @default(now()) @db.DateTime(0)
  updated_at  DateTime                   @default(now()) @db.DateTime(0)
  users       users?                     @relation(fields: [assigned_to], references: [id], map: "fk_contact_submissions_assignee")

  @@index([assigned_to], map: "fk_contact_submissions_assignee")
  @@index([status, created_at], map: "idx_contact_submissions_status")
}

model content_imports {
  id               BigInt                        @id @default(autoincrement()) @db.UnsignedBigInt
  article_id       BigInt?                       @db.UnsignedBigInt
  uploaded_by      BigInt?                       @db.UnsignedBigInt
  source_type      content_imports_source_type
  source_filename  String?                       @db.VarChar(255)
  source_hash      String                        @unique(map: "uq_content_import_source_hash") @db.Char(64)
  raw_markdown     String?                       @db.LongText
  frontmatter_json String?                       @db.LongText
  parsed_data_json String?                       @db.LongText
  import_status    content_imports_import_status @default(pending)
  error_message    String?                       @db.Text
  created_at       DateTime                      @default(now()) @db.DateTime(0)
  completed_at     DateTime?                     @db.DateTime(0)
  articles         articles?                     @relation(fields: [article_id], references: [id], map: "fk_content_import_article")
  users            users?                        @relation(fields: [uploaded_by], references: [id], map: "fk_content_import_user")

  @@index([article_id], map: "fk_content_import_article")
  @@index([uploaded_by], map: "fk_content_import_user")
  @@index([import_status, created_at], map: "idx_content_import_status")
}

model destinations {
  id                   BigInt                        @id @default(autoincrement()) @db.UnsignedBigInt
  parent_id            BigInt?                       @db.UnsignedBigInt
  name                 String                        @db.VarChar(180)
  slug                 String                        @unique(map: "uq_destinations_slug") @db.VarChar(180)
  destination_type     destinations_destination_type @default(town)
  short_description    String?                       @db.VarChar(800)
  content_html         String?                       @db.LongText
  content_json         String?                       @db.LongText
  hero_media_id        BigInt?                       @db.UnsignedBigInt
  latitude             Decimal?                      @db.Decimal(10, 7)
  longitude            Decimal?                      @db.Decimal(10, 7)
  postal_code          String?                       @db.VarChar(20)
  is_featured          Boolean                       @default(false)
  status               destinations_status           @default(draft)
  display_order        Int                           @default(0)
  published_at         DateTime?                     @db.DateTime(0)
  created_at           DateTime                      @default(now()) @db.DateTime(0)
  updated_at           DateTime                      @default(now()) @db.DateTime(0)
  deleted_at           DateTime?                     @db.DateTime(0)
  articles             articles[]
  attractions          attractions[]
  business_submissions business_submissions[]
  businesses           businesses[]
  media                media?                        @relation(fields: [hero_media_id], references: [id], map: "fk_destinations_hero_media")
  destinations         destinations?                 @relation("destinationsTodestinations", fields: [parent_id], references: [id], map: "fk_destinations_parent")
  other_destinations   destinations[]                @relation("destinationsTodestinations")
  events               events[]

  @@index([hero_media_id], map: "fk_destinations_hero_media")
  @@index([parent_id], map: "idx_destinations_parent")
  @@index([status, is_featured], map: "idx_destinations_status_featured")
}

model entity_categories {
  id          BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  entity_type String     @db.VarChar(50)
  entity_id   BigInt     @db.UnsignedBigInt
  category_id BigInt     @db.UnsignedBigInt
  is_primary  Boolean    @default(false)
  created_at  DateTime   @default(now()) @db.DateTime(0)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade, map: "fk_entity_categories_category")

  @@unique([entity_type, entity_id, category_id], map: "uq_entity_category")
  @@index([category_id], map: "idx_entity_categories_category")
  @@index([entity_type, entity_id, is_primary], map: "idx_entity_categories_lookup")
}

model entity_faq_links {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  entity_type   String   @db.VarChar(50)
  entity_id     BigInt   @db.UnsignedBigInt
  faq_id        BigInt   @db.UnsignedBigInt
  display_order Int      @default(0)
  created_at    DateTime @default(now()) @db.DateTime(0)
  faqs          faqs     @relation(fields: [faq_id], references: [id], onDelete: Cascade, map: "fk_entity_faqs_faq")

  @@unique([entity_type, entity_id, faq_id], map: "uq_entity_faq")
  @@index([faq_id], map: "fk_entity_faqs_faq")
  @@index([entity_type, entity_id, display_order], map: "idx_entity_faq_lookup")
}

model entity_media {
  id            BigInt                  @id @default(autoincrement()) @db.UnsignedBigInt
  entity_type   String                  @db.VarChar(50)
  entity_id     BigInt                  @db.UnsignedBigInt
  media_id      BigInt                  @db.UnsignedBigInt
  media_role    entity_media_media_role @default(gallery)
  display_order Int                     @default(0)
  created_at    DateTime                @default(now()) @db.DateTime(0)
  media         media                   @relation(fields: [media_id], references: [id], onDelete: Cascade, map: "fk_entity_media_media")

  @@unique([entity_type, entity_id, media_id, media_role], map: "uq_entity_media")
  @@index([media_id], map: "fk_entity_media_media")
  @@index([entity_type, entity_id, media_role, display_order], map: "idx_entity_media_lookup")
}

model events {
